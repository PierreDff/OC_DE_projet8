# ============================================================
# Variables d'environnement - GreenCoop Data Platform
# ============================================================
# Copier ce fichier en .env et adapter les valeurs.
# NE PAS COMMITER le fichier .env (déjà ignoré dans .gitignore)

# --- PostgreSQL Warehouse ---
POSTGRES_USER=greencoop
POSTGRES_PASSWORD=greencoop_dev_pwd
POSTGRES_DB=greencoop_warehouse

# --- pgAdmin (admin web) ---
PGADMIN_EMAIL=admin@greencoop.local
PGADMIN_PASSWORD=admin
